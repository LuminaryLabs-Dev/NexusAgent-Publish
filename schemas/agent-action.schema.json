{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://luminarylabs.dev/schemas/nexusagent/agent-action.schema.json",
  "title": "NexusAgent Agent Action",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "reason"],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "PLAN_GOAL",
        "READ_FILES",
        "FETCH_CONTEXT",
        "WRITE_FILE",
        "PATCH_FILE",
        "VALIDATE",
        "FINALIZE"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["replace", "append", "create"]
        },
        "old": {
          "type": "string"
        },
        "new": {
          "type": "string"
        }
      }
    },
    "validation_command": {
      "type": "string"
    }
  }
}
